# Required for authenticated NDAX private calls
NDAX_API_KEY=
NDAX_API_SECRET=
NDAX_USER_ID=
# Optional username for GetUserAccounts/GetUserAccountInfos payloads
NDAX_USERNAME=

# Optional NDAX API tuning
NDAX_BASE_URL=https://api.ndax.io/AP
NDAX_OMS_ID=1
NDAX_TIMEOUT_SECONDS=15
NDAX_MAX_RETRIES=3

# Runtime config
QTBOT_RUNTIME_DIR=runtime
QTBOT_CADENCE_SECONDS=60
QTBOT_SIGNAL_INTERVAL_SECONDS=60
QTBOT_EMA_FAST=60
QTBOT_EMA_SLOW=360
QTBOT_ATR_PERIOD=60
QTBOT_STOP_K=2.5
QTBOT_MAX_HOLD_HOURS=48
QTBOT_COOLDOWN_MINUTES=30
QTBOT_MAX_NEW_ENTRIES_PER_CYCLE=3
QTBOT_ENABLE_LIVE_TRADING=false
QTBOT_TAKER_FEE_RATE=0.004
QTBOT_MIN_ORDER_NOTIONAL_CAD=25
QTBOT_ORDER_STATUS_POLL_SECONDS=2
QTBOT_ORDER_STATUS_MAX_ATTEMPTS=15
QTBOT_PREFLIGHT_MIN_WARMUP_COVERAGE=0.8
QTBOT_DAILY_LOSS_CAP_CAD=250
QTBOT_MAX_SLIPPAGE_PCT=0.02
QTBOT_CONSECUTIVE_ERROR_LIMIT=3
QTBOT_DISCORD_WEBHOOK_URL=
QTBOT_DISCORD_TIMEOUT_SECONDS=8
QTBOT_DISCORD_MAX_RETRIES=2
